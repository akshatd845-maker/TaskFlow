# =============================================================================
# TaskFlow - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the required values
# Do NOT commit .env files to version control!

# ── Server Configuration ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development          # development | production | test

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (REQUIRED)
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority
# Example: mongodb+srv://myuser:mypassword@cluster0.abcde.mongodb.net/taskflow?retryWrites=true&w=majority
MONGODB_URI=

# ── Authentication ───────────────────────────────────────────────────────────
# JWT secret key for signing tokens (REQUIRED)
# IMPORTANT: In production, use at least 64 random characters
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Or use: openssl rand -hex 64
JWT_SECRET=

# Optional: JWT token expiration (default: 7d)
# JWT_EXPIRE=7d

# ── CORS (Cross-Origin Resource Sharing) ──────────────────────────────────────
# IMPORTANT: Set to your production frontend URL in production!
# Omitting this will open CORS to all origins (development only)
#
# Development: http://localhost:5173 (Vite default)
# Production: https://your-production-domain.com
CLIENT_URL=http://localhost:5173

# ── Rate Limiting (optional — defaults shown) ─────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100   # requests per window per IP

# ── Logging ───────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=debug

# ── Client Configuration ─────────────────────────────────────────────────────
# (These are read by the client from the server via environment variables)
# VITE_API_URL=http://localhost:5000/api