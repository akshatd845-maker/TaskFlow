# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development          # development | production | test

# ── Database ──────────────────────────────────────────────────
# MongoDB Atlas connection string (REQUIRED)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────────
# Must be at least 64 random characters in production.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_plus_random_characters_in_production

# ── CORS ──────────────────────────────────────────────────────
# Set to your frontend URL. Omitting this opens CORS to all origins (dev only).
CLIENT_URL=http://localhost:5173

# ── Rate Limiting (optional — defaults shown) ─────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes in ms
RATE_LIMIT_MAX_REQUESTS=100   # requests per window per IP

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=debug               # debug | info | warn | error
